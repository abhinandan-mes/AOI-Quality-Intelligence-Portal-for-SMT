generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(INSPECTOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Line {
  id           String    @id @default(uuid())
  name         String    @unique
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  postAoiWatchPath String?
  isInstalled     Boolean   @default(true)
  spiWatchPath    String?
  preAoiWatchPath String?
  machines        Machine[]
}

model Machine {
  id          String       @id @default(uuid())
  machineId   String       @unique
  name        String
  type        MachineType
  lineId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  inspections Inspection[]
  line        Line         @relation(fields: [lineId], references: [id])
}

model ProductModel {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  inspections Inspection[]
}

model Inspection {
  id             String           @id @default(uuid())
  barcode        String
  modelId        String
  machineId      String
  inspectionTime DateTime
  status         InspectionStatus
  isFalseCall    Boolean          @default(false)
  cycleTime      Float?
  spiHeightAvg   Float?
  spiAreaAvg     Float?
  spiVolumeAvg   Float?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  side           String?
  defects        Defect[]
  machine        Machine          @relation(fields: [machineId], references: [id])
  productModel   ProductModel     @relation(fields: [modelId], references: [id])

  @@index([barcode])
  @@index([inspectionTime])
}

model Defect {
  id              String     @id @default(uuid())
  inspectionId    String
  componentName   String
  defectType      String
  defectCount     Int        @default(1)
  imagePath       String?
  engineerComment String?
  repairStatus    String     @default("PENDING")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  blockId         String?
  inspection      Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([componentName])
}

model FileImportLog {
  id           String   @id @default(uuid())
  fileName     String
  fileType     String
  filePath     String?  @unique
  machineId    String?
  status       String
  errorMessage String?
  processedAt  DateTime @default(now())
}

enum Role {
  INSPECTOR
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum MachineType {
  POST_AOI
  SPI
  PRE_AOI
}

enum InspectionStatus {
  PASS
  FAIL
  WARNING
  GOOD
  NG
}

model RolePermission {
  id          String   @id @default(uuid())
  role        Role     @unique
  permissions String[]
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  username  String?
  action    String
  ipAddress String?
  details   String?
  createdAt DateTime @default(now())
}
